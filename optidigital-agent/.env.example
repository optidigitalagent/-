TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
OPENAI_API_KEY=
FREELANCEHUNT_TOKEN=
DATABASE_URL=

# Gmail Agent (optional — disabled by default)
GMAIL_ENABLED=false
GMAIL_USE_MOCK=true
GMAIL_MIN_SCORE=6
GMAIL_CHECK_INTERVAL_MINUTES=30

# Railway-safe: set these to the full JSON content of the credential files
# (copy-paste the file contents as a single-line JSON string)
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=

# File fallback (local development only)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=gmail_token.json
